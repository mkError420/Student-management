rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin') || request.auth.token.email == "mk.rabbani.cse@gmail.com";
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isParent() {
      return hasRole('parent');
    }

    function isStudent() {
      return hasRole('student');
    }

    // Users Collection
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(uid);
      allow update: if isAuthenticated() && (isOwner(uid) || isAdmin());
    }

    // Students Collection
    match /students/{studentId} {
      allow read: if isAdmin() || isTeacher() || (isParent() && resource.data.parentId == request.auth.uid) || (isStudent() && studentId == request.auth.uid);
      allow write: if isAdmin() || isTeacher();
    }

    // Classes Collection
    match /classes/{classId} {
      allow read: if isAdmin() || isTeacher();
      allow write: if isAdmin() || isTeacher();
    }

    // Teachers Collection
    match /teachers/{teacherId} {
      allow read: if isAdmin() || isTeacher();
      allow write: if isAdmin();
    }

    // Attendance Collection
    match /attendance/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    // Fees Collection
    match /fees/{id} {
      allow read: if isAdmin() || (isParent() && get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Exams Collection
    match /exams/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    // Results Collection
    match /results/{id} {
      allow read: if isAdmin() || isTeacher() || (isParent() && get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentId == request.auth.uid) || (isStudent() && resource.data.studentId == request.auth.uid);
      allow write: if isAdmin() || isTeacher();
    }

    // Library Books Collection
    match /library_books/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Library Issues Collection
    match /library_issues/{id} {
      allow read: if isAdmin() || isTeacher() || isOwner(resource.data.studentId);
      allow write: if isAdmin();
    }

    // Staff Collection
    match /staff/{id} {
      allow read: if isAdmin() || isTeacher();
      allow write: if isAdmin();
    }

    // Payroll Collection
    match /payroll/{id} {
      allow read: if isAdmin() || isOwner(resource.data.staffId);
      allow write: if isAdmin();
    }

    // Notifications Collection
    match /notifications/{id} {
      allow read: if isOwner(resource.data.recipientId);
      allow create: if isAdmin() || isTeacher();
      allow update: if isOwner(resource.data.recipientId);
    }
  }
}
